# ── Contact form email (server-side only — never in the browser) ──
RESEND_API_KEY=re_your_resend_api_key_here
CONTACT_TO_EMAIL=kidswowstem@gmail.com
CONTACT_FROM_EMAIL=KidsWow Contact <onboarding@resend.dev>

# ── Cloudflare Turnstile (recommended for production) ──
# 1. https://dash.cloudflare.com → Turnstile → Add site
# 2. Use "Managed" widget; add localhost + your Vercel domain
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Upstash Redis (persistent rate limiting on Vercel) ──
# What it does: remembers submission counts across server restarts/deploys.
# Without it, rate limits reset when Vercel cold-starts a function.
#
# Setup:
# 1. https://console.upstash.com → Create Redis database (free tier)
# 2. Copy "REST URL" and "REST TOKEN" below
# 3. Add the same vars in Vercel → Settings → Environment Variables
# 4. Redeploy
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
