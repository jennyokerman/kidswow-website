# Contact form email (server-side only — never exposed in the browser)
RESEND_API_KEY=re_your_resend_api_key_here
CONTACT_TO_EMAIL=kidswowstem@gmail.com

# Optional: use your own domain after verifying it in Resend
# CONTACT_FROM_EMAIL=KidsWow <contact@kidswow.com>

# Until your domain is verified, Resend's test sender works:
CONTACT_FROM_EMAIL=KidsWow Contact <onboarding@resend.dev>

# Optional: Cloudflare Turnstile (recommended for production spam protection)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
